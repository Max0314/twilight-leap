{
  "name": "twilight-leap",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "serve -s out -l 3000",
    "test": "vitest run --config vitest.config.ts",
    "test:rendered": "npm run build && node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run test && npm run lint && npm run typecheck && npm run test:rendered && npm run audit:prod"
  },
  "dependencies": {
    "next": "16.2.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "serve": "14.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.7"
    },
    "postcss": "8.5.22",
    "sharp": "0.35.3",
    "vite": "8.1.5"
  },
  "type": "module"
}
