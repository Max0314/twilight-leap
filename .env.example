# 宿主机回环端口；外部流量应始终由宿主机 Nginx 转发。
TWILIGHT_LEAP_PORT=23002

# 构建时写入 Open Graph 等绝对链接。完成 ICP 备案与 HTTPS 后改为正式域名。
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:23002

# 可选：自定义本地镜像标签。
TWILIGHT_LEAP_IMAGE=fribench-twilight-leap:local

# Fribench 服务器构建使用的 HTTPS npm 镜像；不修改宿主机全局 npm 配置。
NPM_REGISTRY=https://registry.npmmirror.com
